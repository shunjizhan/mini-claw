# mini-claw environment variables
# Copy to .env (Bun auto-loads it; no dotenv needed) and fill in what you need.

# ------------------------------------------------------------------
# Provider selection
# ------------------------------------------------------------------
# Which provider to use. One of: anthropic | openai
MINI_CC_PROVIDER=anthropic

# Optional model override. Defaults are:
#   anthropic → claude-opus-4-7
#   openai    → gpt-5.4
# Note: not every proxy has the newest models. If you see
# "unknown provider for model X", override here with a model your proxy
# supports (check GET /v1/models).
# MINI_CC_MODEL=claude-opus-4-6

# ------------------------------------------------------------------
# API routing
# ------------------------------------------------------------------
# Base URL for API requests. Defaults to http://localhost:8317 so mini-claw
# targets a local proxy out of the box. Override to hit the real APIs:
#   Anthropic → https://api.anthropic.com
#   OpenAI    → https://api.openai.com/v1
MINI_CC_BASE_URL=http://localhost:8317

# ------------------------------------------------------------------
# Credentials
# ------------------------------------------------------------------
# When MINI_CC_BASE_URL points at a local proxy that doesn't require auth,
# these are optional — mini-claw injects a placeholder key so the SDK can
# instantiate. For direct API access you MUST set the matching key below.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------
# Tests
# ------------------------------------------------------------------
# Opt-in gate for real-API E2E tests (test/e2e/). Unset by default so
# `bun test` stays hermetic.
# MINI_CC_REAL_API=1
